generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
  LATE
}

enum InchargeStatus {
  ACTIVE
  REMOVED
}

enum ExamStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  ABSENT
  ASSIGNMENT
  TEST
  LOW_ATTENDANCE
  GENERAL
}

model User {
  id           String     @id @default(uuid())
  authId       String     @unique
  name         String
  email        String     @unique
  role         Role
  profileImage String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  teacher              Teacher?
  student              Student?
  parent               Parent?
  posts                Post[]
  materials            Material[]
  assignments          Assignment[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  assignedIncharges    ClassIncharge[] @relation("AssignedByAdmin")
}

model Teacher {
  id            String   @id @default(uuid())
  userId        String   @unique
  phone         String?
  qualification String?
  createdAt     DateTime @default(now())

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSubjects   ClassSubject[]
  incharges       ClassIncharge[]
  attendances     Attendance[]
  exams           Exam[]
  teacherSubjects TeacherSubject[]
}

model TeacherSubject {
  id        String @id @default(uuid())
  teacherId String
  subjectId String

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
}

model Student {
  id         String   @id @default(uuid())
  userId     String   @unique
  fatherName String
  rollNumber String   @unique
  classId    String
  group      String?
  phone      String?
  createdAt  DateTime @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  class        Class             @relation(fields: [classId], references: [id])
  parentLinks  ParentStudent[]
  attendances  Attendance[]
  submissions  Submission[]
  examResults  ExamResult[]
}

model Parent {
  id        String   @id @default(uuid())
  userId    String   @unique
  phone     String?
  createdAt DateTime @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentLinks ParentStudent[]
}

model ParentStudent {
  id        String @id @default(uuid())
  parentId  String
  studentId String

  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
}

model Class {
  id           String   @id @default(uuid())
  name         String
  group        String?
  academicYear String   @default("2026")
  createdAt    DateTime @default(now())

  students      Student[]
  classSubjects ClassSubject[]
  incharges     ClassIncharge[]
  posts         Post[]
  materials     Material[]
  assignments   Assignment[]
  lectures      Lecture[]
  attendances   Attendance[]
  exams         Exam[]
  attendanceLocks AttendanceLock[]
}

model Subject {
  id   String @id @default(uuid())
  name String @unique

  classSubjects   ClassSubject[]
  teacherSubjects TeacherSubject[]
  lectures        Lecture[]
  attendances     Attendance[]
  exams           Exam[]
}

model ClassSubject {
  id        String @id @default(uuid())
  classId   String
  subjectId String
  teacherId String?

  class   Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher Teacher? @relation(fields: [teacherId], references: [id])

  @@unique([classId, subjectId])
}

model ClassIncharge {
  id              String         @id @default(uuid())
  classId         String
  teacherId       String
  assignedByAdmin String
  assignedDate    DateTime       @default(now())
  status          InchargeStatus @default(ACTIVE)

  class         Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher       Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  assignedBy    User    @relation("AssignedByAdmin", fields: [assignedByAdmin], references: [id])

  @@unique([classId, teacherId])
}

model Post {
  id          String   @id @default(uuid())
  classId     String
  authorId    String
  title       String
  description String
  attachments String[] @default([])
  createdAt   DateTime @default(now())

  class  Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])
}

model Material {
  id          String   @id @default(uuid())
  classId     String
  title       String
  description String?
  fileUrl     String
  createdById String
  createdAt   DateTime @default(now())

  class     Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id])
}

model Assignment {
  id           String   @id @default(uuid())
  classId      String
  title        String
  instructions String
  deadline     DateTime
  attachments  String[] @default([])
  createdById  String
  createdAt    DateTime @default(now())

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdBy   User         @relation(fields: [createdById], references: [id])
  submissions Submission[]
}

model Submission {
  id           String           @id @default(uuid())
  assignmentId String
  studentId    String
  fileUrl      String?
  grade        Float?
  comment      String?
  status       SubmissionStatus @default(PENDING)
  submittedAt  DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
}

model Lecture {
  id        String   @id @default(uuid())
  classId   String
  subjectId String
  date      DateTime @db.Date
  number    Int

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@unique([classId, subjectId, date, number])
}

model AttendanceLock {
  id      String   @id @default(uuid())
  classId String
  date    DateTime @db.Date
  locked  Boolean  @default(true)
  lockedAt DateTime @default(now())

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, date])
}

model Attendance {
  id        String           @id @default(uuid())
  studentId String
  classId   String
  subjectId String
  lectureId String?
  teacherId String
  date      DateTime         @db.Date
  status    AttendanceStatus
  createdAt DateTime         @default(now())

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  lecture Lecture? @relation(fields: [lectureId], references: [id])
  teacher Teacher  @relation(fields: [teacherId], references: [id])

  @@unique([studentId, classId, subjectId, date])
}

model TestSession {
  id           String   @id @default(uuid())
  name         String
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  instructions String?
  createdAt    DateTime @default(now())

  exams Exam[]
}

model Exam {
  id         String     @id @default(uuid())
  sessionId  String?
  name       String
  subjectId  String
  classId    String
  date       DateTime   @db.Date
  totalMarks Float
  duration   Int?
  teacherId  String?
  status     ExamStatus @default(SCHEDULED)
  createdAt  DateTime   @default(now())

  session TestSession? @relation(fields: [sessionId], references: [id])
  subject Subject      @relation(fields: [subjectId], references: [id])
  class   Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher Teacher?     @relation(fields: [teacherId], references: [id])
  results ExamResult[]
}

model ExamResult {
  id            String @id @default(uuid())
  examId        String
  studentId     String
  marksObtained Float
  percentage    Float
  grade         String

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ContactEnquiry {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String
  program   String?
  message   String?
  createdAt DateTime @default(now())
}
